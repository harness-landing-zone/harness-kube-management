{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "harnessAgent": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "metadata": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "annotations": { "type": "object" },
            "labels": { "type": "object" }
          }
        },
        "spec": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "operator": { "type": "string" },
            "scope": { "type": "string" },
            "type": { "type": "string" },
            "projectId": { "type": "string" },
            "projectMapping": {
              "type": "object",
              "properties": {
                "projectId": { "type": "string" },
                "AppProject": { "type": "string" }
              }
            },
            "existingAgentIdentifier": { "type": "string" },
            "apiKeySecretRef": { "type": "string", "minLength": 1 },
            "tokenSecretRef": { "type": "string", "minLength": 1 }
          },
          "required": ["apiKeySecretRef", "tokenSecretRef"]
        }
      },
      "required": ["enabled", "spec"]
    },
    "appProject": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string" },
        "namespace": { "type": "string" },
        "description": { "type": "string" },
        "annotations": { "type": "object" },
        "labels": { "type": "object" }
      },
      "required": ["enabled"]
    },
    "gitopsAgent": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "harness": {
          "type": "object",
          "properties": {
            "identity": {
              "type": "object",
              "properties": {
                "accountIdentifier": { "type": "string" },
                "orgIdentifier": { "type": "string" },
                "projectIdentifier": { "type": "string" },
                "agentIdentifier": { "type": "string" }
              }
            }
          },
          "required": ["identity"]
        },
        "agent": {
          "type": "object",
          "properties": {
            "existingSecrets": {
              "type": "object",
              "properties": {
                "agentToken": { "type": "string", "minLength": 1 }
              },
              "required": ["agentToken"]
            }
          },
          "required": ["existingSecrets"]
        }
      },
      "required": ["harness", "agent"]
    }
  },
  "required": ["harnessAgent", "appProject", "gitopsAgent"]
}
